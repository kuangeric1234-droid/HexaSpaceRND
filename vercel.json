{
  "headers": [
    {
      "source": "/downloads/hexa-printer-ios.mobileconfig",
      "headers": [
        { "key": "Content-Type", "value": "application/x-apple-aspen-config" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"hexa-printer.mobileconfig\"" }
      ]
    },
    {
      "source": "/tv.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/xero/sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/salto/room-access",
      "schedule": "15 * * * *"
    },
    {
      "path": "/api/reconcile",
      "schedule": "30 20 * * *"
    },
    {
      "path": "/api/overdue-reminders",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/auto-billing",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/event-reminders",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/lead-nurture",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/function-reminders",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/function-nurture",
      "schedule": "0 9 * * *"
    }
  ]
}
